{
  "_readme": "Full JALES API demo playbook. Paths are relative to your API base URL with NO /api prefix (e.g. POST {BASE}/auth/login). Run steps in order; substitute <AUTH_TOKEN>, <USER_ID>, <DEVICE_ID>, <SESSION_ID> from responses. Prerequisites: backend reachable, CORS if testing from web, same user/device MAC as in steps if your DB enforces uniqueness. Optional: use assets/jales_mock_sensor_data.json as reading payloads in your own scripts; this file documents HTTP steps for Postman/curl.",

  "step_01_register": {
    "description": "Register a new user",
    "method": "POST",
    "endpoint": "/auth/register",
    "body": {
      "name": "Mohammad Tester",
      "email": "mohammad@jales.test",
      "password": "Test1234!",
      "age": 22,
      "gender": "male",
      "job_title": "Software Engineering Student"
    },
    "expectedStatus": 201,
    "expectedResponse": {
      "token": "<save this as AUTH_TOKEN>",
      "user": {
        "id": "<save this as USER_ID>",
        "name": "Mohammad Tester",
        "email": "mohammad@jales.test"
      }
    }
  },

  "step_02_login": {
    "description": "Login with the same user — use this token for all subsequent requests",
    "method": "POST",
    "endpoint": "/auth/login",
    "body": {
      "email": "mohammad@jales.test",
      "password": "Test1234!"
    },
    "expectedStatus": 200,
    "expectedResponse": {
      "token": "<save this as AUTH_TOKEN>",
      "user": { "id": "<USER_ID>", "name": "Mohammad Tester" }
    }
  },

  "step_03_set_thresholds": {
    "description": "Set user posture thresholds — customize RULA sensitivity per user",
    "method": "POST",
    "endpoint": "/thresholds",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {
      "neck_threshold": 20,
      "trunk_threshold": 30,
      "shoulder_threshold": 45,
      "alert_delay_seconds": 15
    },
    "expectedStatus": 201
  },

  "step_04_register_device": {
    "description": "Register the JALES smart shirt BLE device",
    "method": "POST",
    "endpoint": "/devices/register",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {
      "mac_address": "AA:BB:CC:DD:EE:FF",
      "device_name": "JALES Shirt v1"
    },
    "expectedStatus": 201,
    "expectedResponse": {
      "id": "<save this as DEVICE_ID>",
      "mac_address": "AA:BB:CC:DD:EE:FF",
      "device_name": "JALES Shirt v1"
    }
  },

  "step_05_start_session": {
    "description": "Start a posture monitoring session",
    "method": "POST",
    "endpoint": "/sessions/start",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {
      "device_id": "<DEVICE_ID>"
    },
    "expectedStatus": 201,
    "expectedResponse": {
      "session_id": "<save this as SESSION_ID>",
      "start_time": "<timestamp>"
    }
  },

  "step_06_posture_readings": {
    "description": "Send 16 posture readings — one per mock scenario. Each reading is a real sensor payload that the backend scores via RULA.",
    "method": "POST",
    "endpoint": "/readings",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {
      "session_id": "<SESSION_ID>",
      "device_id": "<DEVICE_ID>",
      "readings": [
        {
          "scenario": "01 — Perfect posture",
          "bno": { "heading": 0.00, "roll": 0.50, "pitch": 3.00 },
          "mpu1": { "Ax": -14500, "Ay": 200,   "Az": -5300, "Gx": 5,   "Gy": -2,  "Gz": -1 },
          "mpu2": { "Ax": -8500,  "Ay": 300,   "Az": 9700,  "Gx": -3,  "Gy": -1,  "Gz": 2  },
          "recorded_at": "2026-05-11T08:00:00Z",
          "expectedActionLevel": 1, "expectedAlert": false, "expectedVibration": false
        },
        {
          "scenario": "02 — Slight neck tilt",
          "bno": { "heading": 1.20, "roll": 0.80, "pitch": 15.00 },
          "mpu1": { "Ax": -14500, "Ay": 250,   "Az": -5300, "Gx": 8,   "Gy": -3,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 350,   "Az": 9700,  "Gx": -4,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:01:00Z",
          "expectedActionLevel": 2, "expectedAlert": false, "expectedVibration": false
        },
        {
          "scenario": "03 — Forward neck >20deg",
          "bno": { "heading": 2.10, "roll": 1.00, "pitch": 25.00 },
          "mpu1": { "Ax": -14500, "Ay": 300,   "Az": -5300, "Gx": 10,  "Gy": -4,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 400,   "Az": 9700,  "Gx": -5,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:02:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "04 — Severe forward hunch",
          "bno": { "heading": 3.50, "roll": 2.00, "pitch": 68.00 },
          "mpu1": { "Ax": -14500, "Ay": 500,   "Az": -5300, "Gx": 15,  "Gy": -5,  "Gz": -3 },
          "mpu2": { "Ax": -8500,  "Ay": 600,   "Az": 9700,  "Gx": -7,  "Gy": -3,  "Gz": 4  },
          "recorded_at": "2026-05-11T08:03:00Z",
          "expectedActionLevel": 4, "expectedAlert": true, "expectedVibration": true
        },
        {
          "scenario": "05 — Left shoulder elevated",
          "bno": { "heading": 1.00, "roll": 0.60, "pitch": 5.00 },
          "mpu1": { "Ax": -14500, "Ay": 8000,  "Az": -5300, "Gx": 12,  "Gy": -6,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 400,   "Az": 9700,  "Gx": -4,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:04:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "06 — Right shoulder elevated",
          "bno": { "heading": 1.00, "roll": 0.60, "pitch": 5.00 },
          "mpu1": { "Ax": -14500, "Ay": 300,   "Az": -5300, "Gx": 5,   "Gy": -2,  "Gz": -1 },
          "mpu2": { "Ax": -8500,  "Ay": 9800,  "Az": 9680,  "Gx": -120,"Gy": -24, "Gz": 131},
          "recorded_at": "2026-05-11T08:05:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "07 — Both shoulders raised >90deg",
          "bno": { "heading": 2.00, "roll": 1.00, "pitch": 10.00 },
          "mpu1": { "Ax": -14500, "Ay": 13000, "Az": -5300, "Gx": 20,  "Gy": -8,  "Gz": -4 },
          "mpu2": { "Ax": -8500,  "Ay": 12500, "Az": 9680,  "Gx": -15, "Gy": -6,  "Gz": 5  },
          "recorded_at": "2026-05-11T08:06:00Z",
          "expectedActionLevel": 4, "expectedAlert": true, "expectedVibration": true
        },
        {
          "scenario": "08 — Trunk lateral tilt",
          "bno": { "heading": 1.00, "roll": 14.00, "pitch": 8.00 },
          "mpu1": { "Ax": -14500, "Ay": 250,   "Az": -5300, "Gx": 8,   "Gy": -3,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 350,   "Az": 9700,  "Gx": -4,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:07:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "09 — Trunk twist",
          "bno": { "heading": 22.00, "roll": 1.00, "pitch": 6.00 },
          "mpu1": { "Ax": -14500, "Ay": 250,   "Az": -5300, "Gx": 8,   "Gy": -3,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 350,   "Az": 9700,  "Gx": -4,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:08:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "10 — Worst case everything bad",
          "bno": { "heading": 30.00, "roll": 18.00, "pitch": 72.00 },
          "mpu1": { "Ax": -14500, "Ay": 13000, "Az": -5300, "Gx": 25,  "Gy": -10, "Gz": -5 },
          "mpu2": { "Ax": -8500,  "Ay": 12800, "Az": 9680,  "Gx": -20, "Gy": -8,  "Gz": 6  },
          "recorded_at": "2026-05-11T08:09:00Z",
          "expectedActionLevel": 4, "expectedAlert": true, "expectedVibration": true
        },
        {
          "scenario": "11 — Neck extension looking up",
          "bno": { "heading": 0.50, "roll": 0.50, "pitch": -12.00 },
          "mpu1": { "Ax": -14500, "Ay": 200,   "Az": -5300, "Gx": 5,   "Gy": -2,  "Gz": -1 },
          "mpu2": { "Ax": -8500,  "Ay": 300,   "Az": 9700,  "Gx": -3,  "Gy": -1,  "Gz": 2  },
          "recorded_at": "2026-05-11T08:10:00Z",
          "expectedActionLevel": 4, "expectedAlert": true, "expectedVibration": true
        },
        {
          "scenario": "12 — Recovery after bad posture",
          "bno": { "heading": 0.30, "roll": 0.40, "pitch": 4.00 },
          "mpu1": { "Ax": -14500, "Ay": 180,   "Az": -5300, "Gx": 3,   "Gy": -1,  "Gz": -1 },
          "mpu2": { "Ax": -8500,  "Ay": 220,   "Az": 9700,  "Gx": -2,  "Gy": -1,  "Gz": 1  },
          "recorded_at": "2026-05-11T08:11:00Z",
          "expectedActionLevel": 1, "expectedAlert": false, "expectedVibration": false
        },
        {
          "scenario": "13 — Sensor noise jitter",
          "bno": { "heading": 0.12, "roll": 0.23, "pitch": 2.80 },
          "mpu1": { "Ax": -14501, "Ay": 190,   "Az": -5298, "Gx": 2,   "Gy": -1,  "Gz": 0  },
          "mpu2": { "Ax": -8498,  "Ay": 280,   "Az": 9702,  "Gx": -1,  "Gy": 0,   "Gz": 1  },
          "recorded_at": "2026-05-11T08:12:00Z",
          "expectedActionLevel": 1, "expectedAlert": false, "expectedVibration": false
        },
        {
          "scenario": "14 — Good posture maintained",
          "bno": { "heading": 0.20, "roll": 0.30, "pitch": 3.50 },
          "mpu1": { "Ax": -14500, "Ay": 190,   "Az": -5300, "Gx": 4,   "Gy": -1,  "Gz": -1 },
          "mpu2": { "Ax": -8500,  "Ay": 240,   "Az": 9700,  "Gx": -2,  "Gy": -1,  "Gz": 1  },
          "recorded_at": "2026-05-11T08:13:00Z",
          "expectedActionLevel": 1, "expectedAlert": false, "expectedVibration": false
        },
        {
          "scenario": "15 — Moderate hunch sustained",
          "bno": { "heading": 2.00, "roll": 1.20, "pitch": 35.00 },
          "mpu1": { "Ax": -14500, "Ay": 400,   "Az": -5300, "Gx": 11,  "Gy": -4,  "Gz": -2 },
          "mpu2": { "Ax": -8500,  "Ay": 450,   "Az": 9700,  "Gx": -6,  "Gy": -2,  "Gz": 3  },
          "recorded_at": "2026-05-11T08:14:00Z",
          "expectedActionLevel": 3, "expectedAlert": true, "expectedVibration": false
        },
        {
          "scenario": "16 — Final perfect reading",
          "bno": { "heading": 0.10, "roll": 0.20, "pitch": 2.50 },
          "mpu1": { "Ax": -14500, "Ay": 170,   "Az": -5300, "Gx": 2,   "Gy": -1,  "Gz": 0  },
          "mpu2": { "Ax": -8500,  "Ay": 200,   "Az": 9700,  "Gx": -1,  "Gy": 0,   "Gz": 1  },
          "recorded_at": "2026-05-11T08:15:00Z",
          "expectedActionLevel": 1, "expectedAlert": false, "expectedVibration": false
        }
      ]
    }
  },

