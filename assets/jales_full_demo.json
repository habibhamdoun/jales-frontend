  "step_08_end_session": {
    "description": "End the session with computed averages from the 16 readings",
    "method": "PATCH",
    "endpoint": "/sessions/<SESSION_ID>/end",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {
      "avg_neck_angle": 22.4,
      "avg_upper_back_angle": 22.4,
      "avg_left_shoulder_angle": 18.6,
      "avg_right_shoulder_angle": 16.2,
      "avg_action_level": 2.6,
      "total_alerts": 6,
      "posture_score": 56.25
    },
    "expectedStatus": 200
  },

  "step_09_generate_daily_summary": {
    "description": "Generate the daily summary for today after the session ends",
    "method": "POST",
    "endpoint": "/summaries/daily/generate",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {},
    "expectedStatus": 200,
    "expectedResponse": {
      "summary_date": "2026-05-11",
      "avg_neck_angle": 22.4,
      "avg_upper_back_angle": 22.4,
      "total_alerts": 6,
      "total_sessions": 1,
      "good_posture_percentage": 37.5,
      "posture_score": 56.25
    }
  },

  "step_10_generate_weekly_summary": {
    "description": "Generate weekly summary for the current week",
    "method": "POST",
    "endpoint": "/summaries/weekly/generate",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": {},
    "expectedStatus": 200,
    "expectedResponse": {
      "week_start": "2026-05-11",
      "week_end": "2026-05-17",
      "avg_posture_score": 56.25,
      "total_alerts": 6,
      "total_sessions": 1,
      "best_day": "2026-05-11",
      "worst_day": "2026-05-11",
      "improvement_percentage": null
    }
  },

  "step_11_generate_monthly_summary": {
    "description": "Generate monthly summary for May 2026",
    "method": "POST",
    "endpoint": "/summaries/monthly/generate",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "body": { "month": 5, "year": 2026 },
    "expectedStatus": 200,
    "expectedResponse": {
      "month": 5,
      "year": 2026,
      "avg_posture_score": 56.25,
      "total_alerts": 6,
      "total_sessions": 1,
      "improvement_vs_last_month": null
    }
  },

  "step_12_ai_doctor_chat": {
    "description": "Test AI Doctor chat — send 3 messages to test context awareness and conversation history",
    "method": "POST",
    "endpoint": "/ai/chat",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "messages_to_send_in_order": [
      {
        "turn": 1,
        "body": { "message": "How was my posture today?" },
        "expectedBehavior": "AI references today's session data — mentions 6 alerts, 56% posture score, and which body parts were most problematic"
      },
      {
        "turn": 2,
        "body": { "message": "My left shoulder keeps going up. What exercises can help?" },
        "expectedBehavior": "AI gives specific shoulder exercises. Should remember context from turn 1 — knows this is the user's main problem area from today's data"
      },
      {
        "turn": 3,
        "body": { "message": "How long should I wear the shirt each day for best results?" },
        "expectedBehavior": "AI gives a recommendation and ties it back to the user's profile — student, sitting for long hours. Should not give generic advice."
      }
    ]
  },

  "step_13_get_ai_history": {
    "description": "Fetch the full AI chat history — should return all 6 messages (3 user + 3 assistant) in order",
    "method": "GET",
    "endpoint": "/ai/history",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200,
    "expectedResponse": {
      "messages_count": 6,
      "order": "chronological ascending",
      "roles_alternating": true
    }
  },

  "step_14_get_session_details": {
    "description": "Fetch the full session with all readings — used by the history screen in the app",
    "method": "GET",
    "endpoint": "/sessions/<SESSION_ID>",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200,
    "expectedResponse": {
      "session": { "id": "<SESSION_ID>", "total_alerts": 6, "posture_score": 56.25 }
    }
  },

  "step_15_get_readings_for_session": {
    "description": "Fetch all 16 readings for the session — used by the session detail screen",
    "method": "GET",
    "endpoint": "/readings/<SESSION_ID>",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200,
    "expectedResponse": {
      "readings_count": 16,
      "order": "chronological ascending"
    }
  },

  "step_16_get_alerts_for_session": {
    "description": "Fetch all alerts logged during the session — used by the alert history screen",
    "method": "GET",
    "endpoint": "/alerts?session_id=<SESSION_ID>",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200,
    "expectedResponse": {
      "alerts_count": 6,
      "severity_breakdown": {
        "moderate": 2,
        "severe": 4
      }
    }
  },

  "step_17_get_daily_summary": {
    "description": "Fetch today's daily summary — used by the home screen summary card",
    "method": "GET",
    "endpoint": "/summaries/daily?date=2026-05-11",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200
  },

  "step_18_get_daily_range": {
    "description": "Fetch daily summaries for a date range — used by the weekly chart in the app",
    "method": "GET",
    "endpoint": "/summaries/daily/range?start=2026-05-05&end=2026-05-11",
    "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
    "expectedStatus": 200,
    "note": "Only 2026-05-11 will have data. Other days return empty/zero. Confirm the endpoint does not crash on empty days."
  },

  "step_19_error_cases": {
    "description": "Test all error scenarios — confirm the backend handles bad input gracefully",
    "cases": [
      {
        "label": "No token — should return 401",
        "method": "GET",
        "endpoint": "/sessions",
        "headers": {},
        "expectedStatus": 401
      },
      {
        "label": "Wrong password — should return 401",
        "method": "POST",
        "endpoint": "/auth/login",
        "body": { "email": "mohammad@jales.test", "password": "wrongpassword" },
        "expectedStatus": 401
      },
      {
        "label": "Empty readings array — should return 400",
        "method": "POST",
        "endpoint": "/readings",
        "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
        "body": { "session_id": "<SESSION_ID>", "device_id": "<DEVICE_ID>", "readings": [] },
        "expectedStatus": 400
      },
      {
        "label": "Non-existent session — should return 404",
        "method": "GET",
        "endpoint": "/sessions/00000000-0000-0000-0000-000000000000",
        "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
        "expectedStatus": 404
      },
      {
        "label": "Duplicate device registration — should upsert not duplicate",
        "method": "POST",
        "endpoint": "/devices/register",
        "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
        "body": { "mac_address": "AA:BB:CC:DD:EE:FF", "device_name": "JALES Shirt v1 Updated" },
        "expectedStatus": 200,
        "expectedBehavior": "Updates existing record — no second row created in devices table"
      },
      {
        "label": "Daily summary with no readings — should not crash",
        "method": "GET",
        "endpoint": "/summaries/daily?date=2020-01-01",
        "headers": { "Authorization": "Bearer <AUTH_TOKEN>" },
        "expectedStatus": 200,
        "expectedBehavior": "Returns null or zero values gracefully"
      }
    ]
  },

  "full_flow_order": [
    "step_01_register",
    "step_02_login",
    "step_03_set_thresholds",
    "step_04_register_device",
    "step_05_start_session",
    "step_06_posture_readings",
    "step_07_log_alerts",
