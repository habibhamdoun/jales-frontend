      "expectedAlert": true,
      "expectedVibration": false,
      "isPersistenceTest": true,
      "persistenceDurationSeconds": 15,
      "readings": [
        {
          "t": 0,
          "sensorReading": { "bno": { "heading": 2.00, "roll": 1.00, "pitch": 26.00 }, "mpu1": { "Ax": -14500, "Ay": 300, "Az": -5300, "Gx": 10, "Gy": -4, "Gz": -2 }, "mpu2": { "Ax": -8500, "Ay": 400, "Az": 9700, "Gx": -5, "Gy": -2, "Gz": 3 } },
