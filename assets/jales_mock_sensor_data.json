{
  "scenarios": [

    {
      "id": "scenario_01",
      "label": "Perfect posture — all neutral",
      "description": "User sitting perfectly upright. All sensors at baseline. No alert expected.",
      "expectedActionLevel": 1,
      "expectedAlert": false,
      "expectedVibration": false,
      "sensorReading": {
        "bno": { "heading": 0.00, "roll": 0.50, "pitch": 3.00 },
        "mpu1": { "Ax": -14500, "Ay": 200,   "Az": -5300, "Gx": 5,   "Gy": -2,  "Gz": -1  },
        "mpu2": { "Ax": -8500,  "Ay": 300,   "Az": 9700,  "Gx": -3,  "Gy": -1,  "Gz": 2   }
      },
      "expectedScores": {
        "neckFlexion": 3,
        "trunkFlexion": 3,
        "trunkTwist": false,
        "trunkTilt": false,
        "leftShoulderAngle": 2,
        "rightShoulderAngle": 2,
        "neckScore": 1,
        "trunkScore": 1,
        "leftShoulderScore": 1,
        "rightShoulderScore": 1,
        "actionLevel": 1
      }
    },

