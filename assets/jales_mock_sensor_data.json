          "shouldFireAlert": false
        },
        {
          "t": 15,
          "sensorReading": { "bno": { "heading": 2.10, "roll": 1.10, "pitch": 27.50 }, "mpu1": { "Ax": -14500, "Ay": 315, "Az": -5300, "Gx": 10, "Gy": -4, "Gz": -2 }, "mpu2": { "Ax": -8500, "Ay": 408, "Az": 9700, "Gx": -5, "Gy": -2, "Gz": 3 } },
