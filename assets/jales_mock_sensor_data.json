        },
        {
          "t": 3,
          "sensorReading": { "bno": { "heading": 2.10, "roll": 1.10, "pitch": 27.00 }, "mpu1": { "Ax": -14500, "Ay": 310, "Az": -5300, "Gx": 10, "Gy": -4, "Gz": -2 }, "mpu2": { "Ax": -8500, "Ay": 410, "Az": 9700, "Gx": -5, "Gy": -2, "Gz": 3 } },
          "shouldFireAlert": false
        },
        {
          "t": 6,
          "sensorReading": { "bno": { "heading": 2.20, "roll": 1.00, "pitch": 26.50 }, "mpu1": { "Ax": -14500, "Ay": 305, "Az": -5300, "Gx": 10, "Gy": -4, "Gz": -2 }, "mpu2": { "Ax": -8500, "Ay": 405, "Az": 9700, "Gx": -5, "Gy": -2, "Gz": 3 } },
          "shouldFireAlert": false
        },
        {
          "t": 10,
